Algoritmo "Impares0a20"
// Disciplina  : logica de programacao com Visual G
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Apresenta os números ímpares na faixa de 0 a 20
// Autor(a)    : Diego de Carvalho Cabaleiro
// Data        : 17/04/2026

var
   // Seçăo de Declaraçőes das variáveis
   numero: inteiro

inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("---------------------------------------")
   escreval("Números ímpares na faixa de 0 a 20:")
   escreval("---------------------------------------")

   para numero de 0 ate 20 faca
      se (numero mod 2 <> 0) entao
         escreval(numero)
      fimse
   fimpara

   escreval("---------------------------------------")

fimalgoritmo