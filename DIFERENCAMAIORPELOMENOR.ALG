Algoritmo "DiferencaMaiorPeloMenor"
// Disciplina  : Linguagem e Lógica de Programaçăo com Visual G
// Professor   : Jailson Costa dos Santos 
// Descriçăo   :  Ler dois valores numéricos inteiros e apresentar
// o resultado da diferença do maior pelo menor valor.
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 11/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
  A, B, resultado:inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  escreva("Digite um valor: ")
  leia(A)
  escreva("Digite outro valor: ")
  leia(B)
  se A>=B entao
  resultado<- A-B
  senao
  resultado<- B-A
  fimse
  escreva("Essa é a diferença entre os valores: ", resultado)

Fimalgoritmo