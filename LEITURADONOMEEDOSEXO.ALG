Algoritmo "leituradonomeedosexo"
// Disciplina  : Linguagem e Lógica de Programaçăo com Visual G
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Efetuar a leitura do nome e do sexo de uma pessoa
// Autor(a)    : Diego de Carvalho Cabaleiro
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   nome, sexo: caractere

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite seu nome: ")
   leia(nome)
   escreva("Digite seu sexo (Masculino/Feminino): ")
   leia(sexo)
   se sexo = "Masculino" entao
      escreval("Ilmo Sr. ", nome)
   senao se sexo = "Feminino" entao
      escreval("Ilma Sra. ", nome)
   fimse

Fimalgoritmo