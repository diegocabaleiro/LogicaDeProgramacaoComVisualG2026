Algoritmo "Area de um triângulo"
// Disciplina  : Lógica de Programação com Visual G
// Professor   : Jailson Costa dos Santos
// Descrição   : Calcula a área de um triângulo e exibe o resultado
// Autor(a)    : Diego de Carvalho Cabaleiro
// Data atual  : 27/03/2026
Var
// Seção de Declarações das variáveis
base: Real
altura: real
resultado: real
Inicio
// Seção de Comandos, procedimento, funções, operadores, etc...
 escreva("Digite o valor da base do triangulo")
 leia(base)
 escreva("Digite o valor da altura do triangulo")
 leia(altura)
 resultado<-base*altura/2
 escreva("esta é a área do triangulo: ", resultado,"cm²")

Fimalgoritmo